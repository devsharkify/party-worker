# ============================================================================
# Party Worker — environment template
# Copy to .env and fill. Every external integration has a dev/fake impl, so the
# whole stack runs locally with NO real credentials. Real keys only for staging/prod.
# ============================================================================

# --- Core ---
NODE_ENV=development
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:8081
ADMIN_URL=http://localhost:3000
# Public base used to build tracked share links: {PUBLIC_LINK_BASE}/r/{workerId}-{contentId}
PUBLIC_LINK_BASE=http://localhost:4000

# --- Database (Postgres) ---
DATABASE_URL=postgresql://ruthlessravan@localhost:5432/party_worker?schema=public

# --- Cache / Queue (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900           # 15 min (seconds)
JWT_REFRESH_TTL=5184000      # 60 days (seconds)
COOKIE_DOMAIN=localhost

# --- OTP provider (OtpProvider interface) ---
# dev = FakeOtpProvider (DEV_OTP_CODE verifies). Real: authkey (authkey.io) | msg91
# Numbers starting with OTP_BYPASS_PREFIX always use DEV_OTP_CODE and skip real SMS,
# so seeded demo accounts keep working even with a live provider.
OTP_PROVIDER=authkey
DEV_OTP_CODE=000000
OTP_BYPASS_PREFIX=+91900000
# Authkey.io: API key from Dashboard > API, SID = approved OTP template id.
AUTHKEY_API_KEY=
AUTHKEY_SID=35306
AUTHKEY_COMPANY=Party Worker
AUTHKEY_COUNTRY_CODE=91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_DLT_TEMPLATE_ID=

# --- Storage provider (StorageProvider interface) ---
# dev = local disk under apps/api/.storage; real: r2 | b2
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=.storage
STORAGE_PUBLIC_BASE=http://localhost:4000/media
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Push provider (PushProvider interface) ---
# dev = mock (console); real: fcm
PUSH_PROVIDER=mock
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# --- Posting / Instagram (PostingProvider interface) ---
# AssistedShare is always available (no creds). Set INSTAGRAM_PROVIDER=graph + the
# Meta app creds below to use the REAL Instagram Graph API (Content Publishing +
# Insights via a connected Business/Creator account; needs app review in prod).
INSTAGRAM_PROVIDER=mock
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0
META_OAUTH_REDIRECT=http://localhost:4000/social/instagram/callback
INSTAGRAM_SCOPES=instagram_basic,instagram_content_publish,instagram_manage_insights,pages_show_list,business_management
# 32+ char secret used to AES-256-GCM encrypt stored OAuth tokens at rest.
SOCIAL_TOKEN_ENC_KEY=dev-social-token-encryption-key-change-me!
# Where the OAuth callback returns the user after linking (the app profile screen).
SOCIAL_CONNECT_RETURN_URL=http://localhost:8081/profile

# --- Payments (PaymentProvider interface) ---
# dev = mock (auto-approve); real: razorpay
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
MEMBERSHIP_FEE_INR=100

# --- Compliance ---
# When ON, publishing un-MCMC-certified political content is blocked.
MCMC_MODE=on
# Minimum on-screen area (%) the burned AI-content label must cover (IT Rules 2025).
AI_LABEL_MIN_AREA_PCT=10

{
  "name": "party-worker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev:api": "pnpm --filter @pw/api dev",
    "dev:app": "pnpm --filter @pw/app web",
    "dev:admin": "pnpm --filter @pw/admin dev",
    "db:generate": "pnpm --filter @pw/api db:generate",
    "db:push": "pnpm --filter @pw/api db:push",
    "db:migrate": "pnpm --filter @pw/api db:migrate",
    "db:seed": "pnpm --filter @pw/api db:seed",
    "db:reset": "pnpm --filter @pw/api db:reset"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}

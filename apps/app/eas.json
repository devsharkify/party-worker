{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4000",
        "EXPO_PUBLIC_META_APP_ID": "1546425170279710"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "staging",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mytrs-api-production.up.railway.app",
        "EXPO_PUBLIC_META_APP_ID": "1546425170279710"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mytrs-api-production.up.railway.app",
        "EXPO_PUBLIC_META_APP_ID": "1546425170279710"
      }
    }
  },
  "update": {
    "channel": "production"
  },
  "submit": {
    "production": {}
  }
}

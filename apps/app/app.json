{
  "expo": {
    "name": "myTRS",
    "slug": "mytrs",
    "scheme": "mytrs",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/trs-logo-square.png",
    "splash": {
      "image": "./assets/trs-logo-square.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8A820"
    },
    "ios": {
      "bundleIdentifier": "com.devsharkify.mytrs",
      "buildNumber": "2",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:mytrs.app"
      ]
    },
    "android": {
      "package": "com.devsharkify.mytrs",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/trs-logo-square.png",
        "backgroundColor": "#E8A820"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "mytrs.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/721cf13b-a21b-4187-8517-9621c379e0c9"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "myTRS needs your location to verify you are present at the event venue."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "721cf13b-a21b-4187-8517-9621c379e0c9"
      }
    },
    "owner": "rokudigital"
  }
}

// Party Worker — data model. Enums mirror packages/shared/src/enums.ts exactly.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrgUnitType {
  state
  district
  constituency
  mandal
  booth
}

enum Role {
  worker
  booth_leader
  mandal_leader
  constituency_leader
  district_leader
  state_admin
  hq_admin
}

enum Tier {
  karyakarta
  sevak
  pramukh
  nayak
  ratna
}

enum Language {
  te
  en
}

enum SocialPlatform {
  whatsapp
  instagram
  facebook
  youtube
  x
}

enum SocialAccountType {
  personal
  creator
  business
}

enum CreativeType {
  image
  video
  carousel
}

// Worker-submitted creatives need approval before they reach the feed.
// null submissionStatus = created directly by admin/HQ (no review needed).
enum SubmissionStatus {
  pending
  approved
  rejected
}

enum ShareChannel {
  whatsapp_status
  whatsapp
  instagram_story
  instagram_feed
  facebook
  youtube
  copy_link
  other
}

enum ReachSource {
  whatsapp_link
  instagram_insights
}

enum ConsentPurpose {
  data_processing
  social_linking
  content_resharing
  location
}

enum DeviceTier {
  low
  mid
  high
}

enum PaymentStatus {
  created
  pending
  success
  failed
}

enum GrievanceStatus {
  open
  routed
  in_progress
  resolved
  rejected
}

enum NewsStatus {
  draft
  published
}

enum RsvpStatus {
  going
  maybe
  no
}

enum ScoreReason {
  share
  recruit_initial
  recruit_bonus
  event_checkin
  grievance_file
  grievance_resolve
  streak
  decay
  fraud_reversal
  league_promote
  league_demote
  mission_bonus
  news_share
  poll_vote
  contact_register
  task_complete
  voter_survey
}

// ---------------------------------------------------------------------------
// Org hierarchy
// ---------------------------------------------------------------------------

model OrgUnit {
  id        String      @id @default(cuid())
  name      String
  type      OrgUnitType
  parentId  String?
  parent    OrgUnit?    @relation("OrgTree", fields: [parentId], references: [id])
  children  OrgUnit[]   @relation("OrgTree")
  users     User[]
  creatives    Creative[]    @relation("CreativeTarget")
  events       Event[]
  polls        Poll[]
  contacts     Contact[]
  crisisAlerts CrisisAlert[]
  boothTasks   BoothTask[]
  canvassRoutes CanvassRoute[]
  waGroup      WaGroup?
  pools     LeaderboardPool[]
  newsItems NewsItem[]
  voterContacts VoterContact[] @relation("BoothVoterContacts")
  voters        Voter[]        @relation("BoothVoters")
  voterSurveys  VoterSurvey[]  @relation("BoothVoterSurveys")
  voterImports  VoterImport[]  @relation("BoothVoterImports")
  createdAt DateTime    @default(now())

  @@index([parentId])
  @@index([type])
}

// ---------------------------------------------------------------------------
// Users + auth
// ---------------------------------------------------------------------------

model User {
  id                 String     @id @default(cuid())
  phone              String     @unique
  name               String
  photoUrl           String?
  designation        String?
  constituency       String?
  area               String?
  orgUnitId          String
  orgUnit            OrgUnit    @relation(fields: [orgUnitId], references: [id])
  role               Role       @default(worker)
  tier               Tier       @default(karyakarta)
  // Weekly-league competition tier — moved by Monday promote/demote, NOT
  // derived from reputation (unlike `tier`, which stays the badge/honor tier).
  leagueTier         Tier       @default(karyakarta)
  preferredLanguage  Language   @default(te)
  lifetimeReputation Int        @default(0)
  weeklyLeaguePoints Int        @default(0)
  streakDays         Int        @default(0)
  lastActiveAt       DateTime?
  membershipActive   Boolean    @default(false)
  isVerified         Boolean    @default(false)  // auto-set by daily verification cron
  verifiedAt         DateTime?

  recruitedById String?
  recruitedBy   User?     @relation("Recruits", fields: [recruitedById], references: [id])
  recruits      User[]    @relation("Recruits")
  recruitedAt   DateTime?

  socialAccounts   SocialAccount[]
  renders          PersonalizedRender[]
  shareEvents      ShareEvent[]
  scoreEntries     ScoreEntry[]
  consents         ConsentRecord[]
  payments         Payment[]
  refreshTokens    RefreshToken[]
  poolMemberships  PoolMembership[]
  rsvps            Rsvp[]
  checkIns         CheckIn[]
  missionCompletions MissionCompletion[]
  pollVotes          PollVote[]
  contactsRegistered Contact[]
  tasksAssigned      BoothTask[]           @relation("TaskAssignedTo")
  assignedRoutes     CanvassRoute[]        @relation("AssignedRoutes")
  taskCompletions    BoothTaskCompletion[]
  grievancesFiled  Grievance[]          @relation("GrievanceFiledBy")
  grievancesRouted Grievance[]          @relation("GrievanceRoutedTo")
  creativesCreated Creative[]           @relation("CreativeCreatedBy")
  creativesSubmitted Creative[]         @relation("CreativeSubmittedBy")
  templatesCreated Template[]           @relation("TemplateCreatedBy")
  deviceTokens     DeviceToken[]
  voterContacts    VoterContact[]   @relation("WorkerContacts")
  workerProfile    WorkerProfile?

  // Voter-roll access is backend-gated: admins/leaders toggle per member.
  voterAccessEnabled Boolean          @default(false)
  voterUpdates       Voter[]          @relation("VoterUpdates")
  voterSurveys       VoterSurvey[]    @relation("WorkerSurveys")
  voterImports       VoterImport[]    @relation("VoterImportsBy")
  voterAccessLogs    VoterAccessLog[] @relation("VoterAccessLogs")
  voterChanges       VoterChange[]    @relation("VoterChanges")
  fieldLocation      FieldLocation?   @relation("FieldLocation")

  createdAt DateTime @default(now())

  @@index([orgUnitId])
  @@index([role])
}

model WorkerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  skills       String[]
  languages    String[]
  availability String   @default("weekends")
  bio          String?
  updatedAt    DateTime @updatedAt

  @@index([skills])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  familyId  String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([familyId])
}

model OtpChallenge {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model SocialAccount {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        SocialPlatform
  type            SocialAccountType @default(personal)
  handle          String?
  connected       Boolean           @default(false)
  isPrimary       Boolean           @default(false)
  remoteUserId    String?           // IG Business/Creator account id (Graph API)
  accessTokenEnc  String?
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?
  createdAt       DateTime          @default(now())
}

// ---------------------------------------------------------------------------
// Content
// ---------------------------------------------------------------------------

model Template {
  id           String     @id @default(cuid())
  name         String
  canvasWidth  Int        @default(1080)
  canvasHeight Int        @default(1920)
  zones        Json
  createdById  String?
  createdBy    User?      @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  creatives    Creative[]
  createdAt    DateTime   @default(now())
}

model Creative {
  id              String       @id @default(cuid())
  title           String
  type            CreativeType
  sourceKey       String
  thumbnailKey    String?
  templateId      String?
  template        Template?    @relation(fields: [templateId], references: [id])
  captionVariants Json
  languages       Language[]
  // Rapid-response flag: pushes to ALL workers on publish, pinned in the feed.
  isBreaking      Boolean      @default(false)
  missions        Mission[]
  mcmcCertified   Boolean      @default(false)
  mcmcCertId      String?
  aiLabeled       Boolean      @default(true)
  targetOrgUnitId String?
  targetOrgUnit   OrgUnit?     @relation("CreativeTarget", fields: [targetOrgUnitId], references: [id])
  createdById     String
  createdBy       User         @relation("CreativeCreatedBy", fields: [createdById], references: [id])
  videoDurationSec Int?         // seconds; only for type=video
  published       Boolean      @default(false)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime     @default(now())

  // Worker submission + approval. submissionStatus null = admin-created.
  submissionStatus SubmissionStatus?
  submittedById    String?
  submittedBy      User?        @relation("CreativeSubmittedBy", fields: [submittedById], references: [id])
  reviewedById     String?
  reviewedAt       DateTime?
  reviewNote       String?

  renders     PersonalizedRender[]
  shareEvents ShareEvent[]

  @@index([published])
  @@index([targetOrgUnitId])
  @@index([submissionStatus])
}

model PersonalizedRender {
  id                String     @id @default(cuid())
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  creativeId        String
  creative          Creative   @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  deviceTier        DeviceTier @default(mid)
  cachedUrl         String?
  cachedVideoUrl    String?    // webm/mp4 personalized video, if captured on web
  usedServerFallback Boolean   @default(false)
  createdAt         DateTime   @default(now())

  @@unique([userId, creativeId])
}

// ---------------------------------------------------------------------------
// Sharing + reach
// ---------------------------------------------------------------------------

model ShareEvent {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  creativeId        String
  creative          Creative     @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  channel           ShareChannel
  trackedLinkId     String       @unique
  basePointsAwarded Int          @default(0)
  shareIntentAt     DateTime     @default(now())
  createdAt         DateTime     @default(now())

  reachEvents ReachEvent[]
  reachHits   ReachHit[]

  @@index([userId])
  @@index([creativeId])
}

// Aggregated reach per share (or per IG media). uniqueCount drives scoring.
model ReachEvent {
  id            String      @id @default(cuid())
  shareEventId  String?
  shareEvent    ShareEvent? @relation(fields: [shareEventId], references: [id], onDelete: Cascade)
  trackedLinkId String?
  igMediaId     String?
  source        ReachSource
  uniqueCount   Int         @default(0)
  views         Int         @default(0)
  likes         Int         @default(0)
  comments      Int         @default(0)
  awardedPoints Int         @default(0)
  updatedAt     DateTime    @updatedAt
  createdAt     DateTime    @default(now())

  @@unique([shareEventId, source])
  @@index([trackedLinkId])
  @@index([igMediaId])
}

// Dedup ledger for unique link taps. dedupHash = SHA256(daily_salt + IP/24 + UA + ids).
// Daily salt is ephemeral so hashes are not reversible (DPDP-clean).
model ReachHit {
  id            String     @id @default(cuid())
  trackedLinkId String
  shareEventId  String?
  shareEvent    ShareEvent? @relation(fields: [shareEventId], references: [id], onDelete: Cascade)
  dedupHash     String
  day           String // YYYY-MM-DD bucket for the 24h dedup window
  createdAt     DateTime   @default(now())

  @@unique([trackedLinkId, dedupHash, day])
  @@index([trackedLinkId])
}

// ---------------------------------------------------------------------------
// Scoring + leaderboards
// ---------------------------------------------------------------------------

model ScoreEntry {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason        ScoreReason
  points        Int
  weeklyDelta   Int         @default(0)
  lifetimeDelta Int         @default(0)
  meta          Json?
  createdAt     DateTime    @default(now())

  @@index([userId])
  @@index([reason])
}

model LeaderboardPool {
  id          String   @id @default(cuid())
  tier        Tier
  weekStart   DateTime
  orgUnitId   String?
  orgUnit     OrgUnit? @relation(fields: [orgUnitId], references: [id])
  sealed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  members PoolMembership[]

  @@index([tier, weekStart])
}

model PoolMembership {
  id       String          @id @default(cuid())
  poolId   String
  pool     LeaderboardPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  points   Int             @default(0)
  rank     Int?
  promoted Boolean?
  demoted  Boolean?

  @@unique([poolId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Events, grievances, consent, payments
// ---------------------------------------------------------------------------

model Event {
  id               String    @id @default(cuid())
  title            String
  description      String?
  startsAt         DateTime
  location         String?
  lat              Float?
  lng              Float?
  qrToken          String    @unique
  orgUnitId        String?
  orgUnit          OrgUnit?  @relation(fields: [orgUnitId], references: [id])
  collagePostedAt  DateTime?
  createdAt        DateTime  @default(now())

  rsvps    Rsvp[]
  checkIns CheckIn[]
}

model Rsvp {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RsvpStatus @default(going)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
}

model CheckIn {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float?
  lng       Float?
  verified  Boolean  @default(false)
  photoKey  String?
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model Grievance {
  id              String          @id @default(cuid())
  title           String
  category        String?
  description     String?
  citizenName     String?
  citizenPhone    String?
  location        String?
  lat             Float?
  lng             Float?
  photoKey        String?
  status          GrievanceStatus @default(open)
  filedById       String
  filedBy         User            @relation("GrievanceFiledBy", fields: [filedById], references: [id])
  routedToId      String?
  routedTo        User?           @relation("GrievanceRoutedTo", fields: [routedToId], references: [id])
  orgUnitId       String?
  createdAt       DateTime        @default(now())
  resolvedAt      DateTime?
  agingPostedAt   DateTime?       // set when an aging auto-poster news item was created

  @@index([status])
  @@index([agingPostedAt])
}

/// Festival / birthday / anniversary push events — daily cron at 06:00 IST sends each.
model PosterCalendar {
  id          String    @id @default(cuid())
  date        DateTime  // day only (time stored as 00:00 UTC)
  title       String
  pushTitle   String
  pushBody    String
  creativeId  String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([date])
}

model ConsentRecord {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   ConsentPurpose
  granted   Boolean        @default(false)
  grantedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime       @default(now())

  @@unique([userId, purpose])
}

// HQ (or a leader) broadcast to all workers or an org subtree. createdById is a
// plain scalar FK (no relation) to keep the User model untouched.
model Announcement {
  id              String   @id @default(cuid())
  title           String
  body            String
  targetOrgUnitId String?
  createdById     String
  createdAt       DateTime @default(now())

  @@index([targetOrgUnitId])
  @@index([createdAt])
}

// A leader-generated invite to self-register into a specific unit + role.
model InviteLink {
  id           String    @id @default(cuid())
  token        String    @unique
  orgUnitId    String
  role         Role      @default(worker)
  createdById  String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  acceptedById String?
  acceptedAt   DateTime?

  @@index([orgUnitId])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountInr   Int
  status      PaymentStatus @default(created)
  provider    String        @default("mock")
  providerRef String?
  createdAt   DateTime      @default(now())
  paidAt      DateTime?

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Push notifications
// ---------------------------------------------------------------------------

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------------
// News
// ---------------------------------------------------------------------------

model NewsItem {
  id          String     @id @default(cuid())
  handle      String     @default("admin") // source handle e.g. "@KCRofficial"
  title       String
  body        String
  imageUrl    String?
  sourceUrl   String?
  status      NewsStatus @default(published)
  isBreaking  Boolean    @default(false)
  shareCount  Int        @default(0)
  publishedAt DateTime   @default(now())
  createdAt   DateTime   @default(now())
  orgUnitId   String?
  orgUnit     OrgUnit?   @relation(fields: [orgUnitId], references: [id])

  @@index([publishedAt])
  @@index([handle])
  @@index([status])
  @@index([isBreaking])
}

/// Timed "Trend Alert" mission: share within the window for bonus points.
model Mission {
  id          String   @id @default(cuid())
  title       String
  caption     String?
  hashtag     String?
  creativeId  String?
  creative    Creative? @relation(fields: [creativeId], references: [id], onDelete: SetNull)
  bonusPoints Int      @default(10)
  startsAt    DateTime
  endsAt      DateTime
  createdById String
  createdAt   DateTime @default(now())

  completions MissionCompletion[]

  @@index([endsAt])
}

model MissionCompletion {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([missionId, userId])
}

/// Leader-created yes/no poll scoped to an org unit. Workers vote and earn points.
model Poll {
  id          String    @id @default(cuid())
  question    String
  optionA     String    @default("అవును / Yes")
  optionB     String    @default("కాదు / No")
  orgUnitId   String?
  orgUnit     OrgUnit?  @relation(fields: [orgUnitId], references: [id])
  createdById String
  endsAt      DateTime
  createdAt   DateTime  @default(now())

  votes PollVote[]

  @@index([endsAt])
  @@index([orgUnitId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  choice    String   // "A" or "B"
  createdAt DateTime @default(now())

  @@unique([pollId, userId])
  @@index([pollId])
}

/// Voter/citizen contact registered by a TRS worker in their booth area.
model Contact {
  id           String   @id @default(cuid())
  name         String
  phone        String?
  address      String?
  notes        String?
  registeredById String
  registeredBy   User     @relation(fields: [registeredById], references: [id])
  orgUnitId    String?
  orgUnit      OrgUnit? @relation(fields: [orgUnitId], references: [id])
  createdAt    DateTime @default(now())

  @@index([registeredById])
  @@index([orgUnitId])
}

/// Active crisis alerts broadcast by leaders — all workers see a red banner.
model CrisisAlert {
  id          String    @id @default(cuid())
  title       String
  message     String
  createdById String
  orgUnitId   String?
  orgUnit     OrgUnit?  @relation(fields: [orgUnitId], references: [id])
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([resolvedAt])
  @@index([orgUnitId])
}

/// BJP/Congress activity tracker — admin logs rival moves, leaders log TRS responses.
model OppositionItem {
  id          String   @id @default(cuid())
  party       String   // "BJP" | "Congress" | "Other"
  headline    String
  details     String?
  trsResponse String?
  createdById String
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

/// Structured activity feed — admins log opposition events with factual counter-points.
model OppositionActivity {
  id           String   @id @default(cuid())
  partyName    String   // "BJP" | "Congress" | "BJP-Congress" | "Other"
  activityType String   // "rally" | "statement" | "controversy" | "policy_attack" | "fake_news"
  title        String
  description  String
  counterPoint String
  mediaUrl     String?
  location     String?
  occurredAt   DateTime
  createdById  String
  createdAt    DateTime @default(now())

  @@index([occurredAt])
  @@index([partyName])
  @@index([activityType])
  @@index([createdAt])
}

/// Booth leader-assigned ground task (door knocking, pamphlet, meeting attendance).
model BoothTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  orgUnitId   String
  orgUnit     OrgUnit   @relation(fields: [orgUnitId], references: [id])
  assignedToId String?
  assignedTo  User?     @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdById String
  dueAt       DateTime?
  createdAt   DateTime  @default(now())

  completions BoothTaskCompletion[]

  @@index([orgUnitId])
  @@index([assignedToId])
}

model BoothTaskCompletion {
  id         String    @id @default(cuid())
  taskId     String
  task       BoothTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       String?
  createdAt  DateTime  @default(now())

  @@unique([taskId, userId])
}

/// WhatsApp group link managed per org unit — workers tap to join.
model WaGroup {
  id        String   @id @default(cuid())
  orgUnitId String   @unique
  orgUnit   OrgUnit  @relation(fields: [orgUnitId], references: [id])
  link      String
  label     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// Door-to-door voter contacts logged by party workers.
model VoterContact {
  id          String   @id @default(cuid())
  workerId    String
  worker      User     @relation("WorkerContacts", fields: [workerId], references: [id])
  boothId     String
  booth       OrgUnit  @relation("BoothVoterContacts", fields: [boothId], references: [id])
  voterName   String
  voterPhone  String?
  address     String?
  sentiment   String
  issue       String?
  notes       String?
  contactedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([workerId])
  @@index([boothId])
}

/// Party manifesto promise with live status tracking visible to all workers.
model ManifestoItem {
  id          String    @id @default(cuid())
  title       String
  description String
  category    String    // "infrastructure" | "welfare" | "education" | "health" | "economy"
  status      String    @default("promised") // "promised" | "in_progress" | "completed" | "delayed"
  progressPct Int       @default(0)
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([status])
}

/// Canvassing route for a booth — ordered list of addresses/areas a worker follows door-to-door.
/// Modelled after MiniVAN (US Democrats) and BJP Shakti portal route assignment.
model CanvassRoute {
  id          String    @id @default(cuid())
  boothId     String
  orgUnit     OrgUnit   @relation(fields: [boothId], references: [id])
  name        String    // e.g. "Sector 4 North Block"
  areas       Json      // Array of { address: string, landmark?: string, priority: number }
  assignedTo  String?
  worker      User?     @relation("AssignedRoutes", fields: [assignedTo], references: [id])
  status      String    @default("unassigned") // "unassigned" | "assigned" | "in_progress" | "completed"
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([boothId])
  @@index([assignedTo])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Voter roll (electoral roll engine — full voter_connect port, org-scoped)
// ---------------------------------------------------------------------------

/// One electoral-roll voter, imported from CSV and pinned to a polling-booth
/// org unit. That single boothId FK is what drives all hierarchy scoping:
/// a leader sees exactly the voters under their org subtree.
model Voter {
  id           String  @id @default(cuid())
  epicNo       String? // ECI EPIC card number
  serialNo     Int?    // serial within the part
  nameEn       String
  nameTe       String? // regional-language name from the roll (V1)
  relationName String? // father/husband name on the roll
  relationType String? // "father" | "husband" | "mother" | "guardian" | "other"
  gender       String? // "M" | "F" | "O"
  age          Int?
  houseNo      String?
  address      String?
  mobile       String?
  partNo       Int?    // ECI part number
  sectionNo    Int?
  acNo         Int?    // assembly constituency number

  boothId String
  booth   OrgUnit @relation("BoothVoters", fields: [boothId], references: [id])

  votingStatus String    @default("unmarked") // "unmarked" | "green" (support) | "yellow" (neutral) | "red" (opposed)
  isVoted      Boolean   @default(false) // election-day turnout mark
  votedAt      DateTime?
  notes        String?
  // House geotag, marked on the doorstep by the booth worker.
  latitude     Float?
  longitude    Float?

  updatedById String?
  updatedBy   User?   @relation("VoterUpdates", fields: [updatedById], references: [id])

  importId String?
  import   VoterImport? @relation(fields: [importId], references: [id])

  surveys VoterSurvey[]
  changes VoterChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boothId, epicNo])
  @@index([boothId, partNo, serialNo])
  @@index([boothId, houseNo])
  @@index([boothId, votingStatus])
  @@index([nameEn])
}

/// One CSV import batch — the audit anchor for where roll data came from.
model VoterImport {
  id           String  @id @default(cuid())
  boothId      String
  booth        OrgUnit @relation("BoothVoterImports", fields: [boothId], references: [id])
  uploadedById String
  uploadedBy   User    @relation("VoterImportsBy", fields: [uploadedById], references: [id])
  filename     String?
  totalRows    Int
  imported     Int
  skipped      Int
  errors       Json?
  voters       Voter[]
  createdAt    DateTime @default(now())

  @@index([boothId])
}

/// Door-to-door household survey (voter_connect FormData port).
model VoterSurvey {
  id       String  @id @default(cuid())
  workerId String
  worker   User    @relation("WorkerSurveys", fields: [workerId], references: [id])
  boothId  String
  booth    OrgUnit @relation("BoothVoterSurveys", fields: [boothId], references: [id])
  voterId  String?
  voter    Voter?  @relation(fields: [voterId], references: [id])

  householdName      String
  mobile             String?
  address            String?
  religion           String?
  caste              String?
  familyMembersCount Int     @default(1)
  familyDetails      Json?   // [{ name, age, gender, relation, isVoter, epicNo? }]
  knowsLocalLeader   Boolean?
  currentPartySupport String? // party name
  supportLevel       String?  // "strong" | "leaning" | "neutral" | "opposed"
  servicesReceived   String?
  incomeRange        String?  // "<10k" | "10-25k" | "25-50k" | "50k+"
  mainOccupation     String?
  housingType        String?  // "owned" | "rented" | "other"
  issues             String?
  latitude           Float?
  longitude          Float?
  visitDate          DateTime @default(now())
  createdAt          DateTime @default(now())

  @@index([workerId])
  @@index([boothId])
  @@index([voterId])
}

/// Every voter-data touch is logged — DPDP accountability + worker protection.
model VoterAccessLog {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation("VoterAccessLogs", fields: [userId], references: [id])
  action    String  // "list" | "search" | "view" | "update" | "bulk_update" | "import" | "stats" | "grant" | "revoke" | "survey_list"
  orgUnitId String?
  voterId   String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

/// Latest known field position per worker — one row per user, upserted by the
/// duty heartbeat. Consent-gated (ConsentPurpose.location) and honest: only
/// updates while the app is open and duty is on.
model FieldLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation("FieldLocation", fields: [userId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  accuracy  Float?
  onDuty    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@index([onDuty])
}

/// Per-voter edit trail (voter_connect change-log port): what changed, by whom.
model VoterChange {
  id        String   @id @default(cuid())
  voterId   String
  voter     Voter    @relation(fields: [voterId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("VoterChanges", fields: [userId], references: [id])
  changes   Json     // [{ field, from, to }]
  createdAt DateTime @default(now())

  @@index([voterId, createdAt])
  @@index([userId, createdAt])
}
